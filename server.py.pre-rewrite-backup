    def _gather_subject_context(self, subject):
            """Read all .md files from a subject's raw/ + wiki/ dirs into a single string."""
            parts = []
            total_chars = 0
            subj_dir = os.path.join(VAULT, "subjects", subject)
            if not os.path.isdir(subj_dir):
                return ""
            for subdir in ("raw", "wiki"):
                d = os.path.join(subj_dir, subdir)
                if not os.path.isdir(d):
                    continue
                for fname in sorted(os.listdir(d)):
                    if not fname.endswith(".md"):
                        continue
                    fpath = os.path.join(d, fname)
                    try:
                        with open(fpath, "r", encoding="utf-8") as f:
                            content = f.read()
                    except Exception:
                        continue
                    label = f"[{subdir}/{fname}]"
                    if total_chars + len(content) + len(label) > _LLM_MAX_CONTEXT_CHARS:
                        remaining = _LLM_MAX_CONTEXT_CHARS - total_chars - len(label) - 20
                        if remaining > 200:
                            parts.append(f"{label}\n{content[:remaining]}\n...[truncated]")
                        break
                    parts.append(f"{label}\n{content}")
                    total_chars += len(content) + len(label)
            return "\n\n".join(parts)

    def _build_subject_index(self, subject):
        """Build a lightweight file index (names + first-line summaries) for a subject."""
        subj_dir = os.path.join(VAULT, "subjects", subject)
        if not os.path.isdir(subj_dir):
            return [], ""
        file_list = []
        for subdir in ("raw", "wiki"):
            d = os.path.join(subj_dir, subdir)
            if not os.path.isdir(d):
                continue
            for fname in sorted(os.listdir(d)):
                if not fname.endswith(".md"):
                    continue
                fpath = os.path.join(d, fname)
                summary = ""
                try:
                    with open(fpath, "r", encoding="utf-8") as f:
                        first_line = f.readline(200).strip()
                        if first_line:
                            summary = first_line[:120]
                except Exception:
                    pass
                file_list.append({"subdir": subdir, "fname": fname, "summary": summary})
        # Read SCHEMA.md separately
        schema_path = os.path.join(subj_dir, "SCHEMA.md")
        schema = ""
        if os.path.isfile(schema_path):
            try:
                with open(schema_path, "r", encoding="utf-8") as f:
                    schema = f.read()[:3000]
            except Exception:
                pass
        return file_list, schema

    def _read_subject_files(self, subject, filenames):
        """Read specific files from a subject by filename. Returns dict {fname: content}."""
        subj_dir = os.path.join(VAULT, "subjects", subject)
        result = {}
        for subdir in ("raw", "wiki"):
            for fname in filenames:
                fpath = os.path.join(subj_dir, subdir, fname)
                if os.path.isfile(fpath):
                    try:
                        with open(fpath, "r", encoding="utf-8") as f:
                            result[fname] = f.read()[:8000]  # cap per file
                    except Exception:
                        pass
        return result

    def _read_vault_file(self, subject, rel_path):
        """Read a file from the vault, validating path is within subject dir.
        Returns (content, error)."""
        subj_dir = os.path.realpath(os.path.join(VAULT, "subjects", subject))

        # Handle edge cases
        rel_path = rel_path.strip().lstrip("/").lstrip(".")

        # If it's empty or just ".", try the index
        if not rel_path or rel_path == ".":
            idx_path = os.path.join(subj_dir, "index.md")
            if os.path.isfile(idx_path):
                try:
                    with open(idx_path, "r", encoding="utf-8") as f:
                        return f.read(50000), None
                except Exception as e:
                    return None, str(e)
            return None, "Debes especificar un archivo concreto. Usa 'wiki/nombre.md' o 'raw/nombre.md'. Consulta la lista de ARCHIVOS DISPONIBLES."

        # If rel_path has no subdirectory (just "pcm.md"), scan wiki/ then raw/
        if "/" not in rel_path:
            # Try wiki/{filename}
            wiki_try = os.path.realpath(os.path.join(subj_dir, "wiki", rel_path))
            if os.path.isfile(wiki_try) and wiki_try.startswith(subj_dir + "/"):
                rel_path = f"wiki/{rel_path}"
            else:
                # Try raw/{filename}
                raw_try = os.path.realpath(os.path.join(subj_dir, "raw", rel_path))
                if os.path.isfile(raw_try) and raw_try.startswith(subj_dir + "/"):
                    rel_path = f"raw/{rel_path}"

        target = os.path.realpath(os.path.join(subj_dir, rel_path))
        if not target.startswith(subj_dir + "/"):
            return None, "Acceso denegado: path fuera del directorio de la materia"
        if not os.path.isfile(target):
            return None, f"Archivo no encontrado: {rel_path}. Verifica que el path exista en ARCHIVOS DISPONIBLES."
        if os.path.getsize(target) > 100_000:
            return None, f"Archivo demasiado grande (>100KB): {rel_path}"
        try:
            with open(target, "r", encoding="utf-8") as f:
                content = f.read(50000)
            return content, None
        except Exception as e:
            return None, str(e)

    def _select_files_by_keywords(self, message, file_index, max_files=5):
        """Score files by keyword overlap with the user's message. Returns list of rel_paths."""
        STOP_WORDS = {
            "que", "del", "las", "los", "por", "para", "con", "una", "uno",
            "como", "mas", "pero", "sus", "son", "era", "han", "has", "hay",
            "the", "and", "for", "are", "its", "has", "had", "but", "not",
            "what", "this", "that", "from", "they", "you", "all", "can",
        }
        words = re.findall(r"[a-záéíóúñü]{3,}", message.lower())
        keywords = {w for w in words if w not in STOP_WORDS}
        if not keywords:
            # Fallback: return first N wiki files
            wiki_files = [fi for fi in file_index if fi["subdir"] == "wiki"]
            return [f"wiki/{fi['fname']}" for fi in wiki_files[:max_files]]

        scored = []
        for fi in file_index:
            score = 0
            text = (fi["fname"] + " " + fi["summary"]).lower()
            for kw in keywords:
                if kw in text:
                    score += 1
            if score > 0:
                scored.append((score, fi))
        scored.sort(key=lambda x: -x[0])

        selected = scored[:max_files]
        return [f"{fi['subdir']}/{fi['fname']}" for _, fi in selected]

    def _extract_file_requests(self, text):
        """Extract [READ: path] markers from LLM response text."""
        markers = re.findall(r'\[READ:\s*(.*?)\]', text)
        return [m.strip() for m in markers if m.strip()]

